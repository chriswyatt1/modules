nextflow_workflow {

    name "Test Subworkflow SYRI_SYNTENY"
    script "../main.nf"
    workflow "SYRI_SYNTENY"

    tag "subworkflows"
    tag "subworkflows_nfcore"
    tag "subworkflows/syri_synteny"
    tag "syri"
    tag "minimap2/align"
    tag "plotsr"

    test("sarscov2 - genome_fasta vs genome_fasta") {

        when {
            workflow {
                """
                input[0] = [
                    [ id:'ecoli_k12' ],
                    file('https://ftp.ncbi.nlm.nih.gov/genomes/all/GCF/000/005/845/GCF_000005845.2_ASM584v2/GCF_000005845.2_ASM584v2_genomic.fna.gz', checkIfExists: true)
                ]
                input[1] = [
                    [ id:'ecoli_o157' ],
                    file('https://ftp.ncbi.nlm.nih.gov/genomes/all/GCF/000/008/865/GCF_000008865.2_ASM886v2/GCF_000008865.2_ASM886v2_genomic.fna.gz', checkIfExists: true)
                ]
                """
            }
        }

        then {
            assert workflow.success
            assert workflow.out.png.size() > 0
            assert snapshot(workflow.out).match()
        }
    }


    test("sarscov2 - genome_fasta vs genome_fasta stub") {

        options "-stub"

        when {
            workflow {
                """
                input[0] = [
                    [ id:'ecoli_k12' ],
                    file('https://ftp.ncbi.nlm.nih.gov/genomes/all/GCF/000/005/845/GCF_000005845.2_ASM584v2/GCF_000005845.2_ASM584v2_genomic.fna.gz', checkIfExists: true)
                ]
                input[1] = [
                    [ id:'ecoli_o157' ],
                    file('https://ftp.ncbi.nlm.nih.gov/genomes/all/GCF/000/008/865/GCF_000008865.2_ASM886v2/GCF_000008865.2_ASM886v2_genomic.fna.gz', checkIfExists: true)
                ]
                """
            }
        }

        then {
            assert workflow.success
            assert workflow.out.png.size() > 0
            assert snapshot(workflow.out).match()
        }
    }
}
