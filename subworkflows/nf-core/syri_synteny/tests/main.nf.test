nextflow_workflow {

    name "Test Subworkflow SYRI_SYNTENY"
    script "../main.nf"
    workflow "SYRI_SYNTENY"

    tag "subworkflows"
    tag "subworkflows_nfcore"
    tag "subworkflows/syri_synteny"
    tag "syri"
    tag "minimap2/align"
    tag "plotsr"

    test("sarscov2 - scaffolds_fasta - genome_fasta") {

        when {
            workflow {
                """
                input[0] = [
                    [ id:'test_query' ],
                    file(params.modules_testdata_base_path + 'genomics/sarscov2/genome/genome.fasta', checkIfExists: true, stageAs: 'query.fasta')
                ]

                input[1] = [
                    [ id:'test_ref' ],
                    file(params.modules_testdata_base_path + 'genomics/sarscov2/genome/genome.fasta', checkIfExists: true)
                ]
                """
            }
        }

        then {
            assert workflow.success
            assert snapshot(workflow.out).match()
        }
    }


    test("sarscov2 - scaffolds_fasta - genome_fasta - stub") {

        options "-stub"

        when {
            workflow {
                """
                input[0] = [
                    [ id:'test_query' ],
                    file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/fasta/scaffolds.fasta', checkIfExists: true)
                ]
                input[1] = [
                    [ id:'test_ref' ],
                    file(params.modules_testdata_base_path + 'genomics/sarscov2/genome/genome.fasta', checkIfExists: true)
                ]
                """
            }
        }

        then {
            assert workflow.success
            assert snapshot(workflow.out).match()
        }
    }
}
